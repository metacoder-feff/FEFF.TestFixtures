<Project>

  <PropertyGroup>
    <!-- MAIN -->
    <LangVersion>14.0</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    
    <!-- Tweaks -->
    <Nullable>enable</Nullable>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <RestorePackagesWithLockFile>true</RestorePackagesWithLockFile>

    <!-- NUGET -->
    <IsPackable>false</IsPackable> <!-- need override in each lib -->
    <VersionPrefix>1.2.0</VersionPrefix>
    <Authors>metacoder-feff</Authors>
    <Copyright>Copyright (c) Metacoder-feff 2026</Copyright>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <Description>Reusable testing components.</Description>
    <RepositoryUrl>https://github.com/metacoder-feff/FEFF.TestFixtures</RepositoryUrl>
    <PackageTags>testing;fixtures</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <!-- PDB/SourceLink -->
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <!-- PDB/SourceLink FIX: Contains untracked sources (e.g. GlobalUsings.g.cs - autogenerated) -->
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <!-- SourceLink adds 'branch' attribute to package -->
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <!-- https://learn.microsoft.com/en-us/dotnet/fundamentals/apicompat/package-validation/overview -->
    <EnablePackageValidation>true</EnablePackageValidation>
  </PropertyGroup>

  <ItemGroup>
    <!-- NUGET -->
    <PackageReference Include="Microsoft.SourceLink.GitHub" Version="10.0.201" PrivateAssets="All"/>
    <None Include="../../README.md" Pack="true" PackagePath="\"/>
  </ItemGroup>

</Project>

