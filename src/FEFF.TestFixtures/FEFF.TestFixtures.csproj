<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>

    <!-- Tweaks -->
    <Nullable>enable</Nullable>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <RestorePackagesWithLockFile>true</RestorePackagesWithLockFile>

    <!-- NUGET -->
    <PackageId>FEFF.TestFixtures</PackageId>
    <Version>1.0.2</Version>
    <Authors>metacoder-feff</Authors>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <Description>Reusable testing components.</Description>
    <RepositoryUrl>https://github.com/metacoder-feff/FEFF.TestFixtures</RepositoryUrl>
    <PackageTags>testing;fixtures</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="FEFF.TestFixtures.Tests" />
    
    <!-- 
      To access FEFF.Extentions.ThrowHelper
      Remove this after link to nuget FEFF.Extentions
    -->
    <InternalsVisibleTo Include="FEFF.TestFixtures.XunitV3" />
    <InternalsVisibleTo Include="FEFF.TestFixtures.AspNetCore" />
  </ItemGroup>
  
  <ItemGroup>
  </ItemGroup>
  
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.0.3" />
  </ItemGroup>

</Project>
