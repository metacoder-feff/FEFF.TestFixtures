<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>

    <!-- Tweaks -->
    <Nullable>enable</Nullable>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <RestorePackagesWithLockFile>true</RestorePackagesWithLockFile>

    <!-- NUGET -->
    <PackageId>FEFF.TestFixtures</PackageId>
    <Version>1.0.0</Version>
    <Authors>metacoder-feff</Authors>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <Description>Reusable testing components.</Description>
    <RepositoryUrl>https://github.com/metacoder-feff/FEFF.TestFixtures</RepositoryUrl>
    <PackageTags>testing;fixtures</PackageTags>
  </PropertyGroup>

  <ItemGroup>
     <InternalsVisibleTo Include="FEFF.TestFixtures.Tests" />
     <InternalsVisibleTo Include="FEFF.TestFixtures.Xunit" />
     <InternalsVisibleTo Include="FEFF.TestFixtures.AspNetCore" />
  </ItemGroup>
  
  <ItemGroup>
  </ItemGroup>
  
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.0.3" />
  </ItemGroup>

</Project>
